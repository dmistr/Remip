    def t(self, key, param=None):
        text = translations[self.current_lang].get(key, key)
        if param is not None:
            return text.format(param)
        return text
        
    def on_language_change(self, event):
        self.current_lang = "ru" if self.lang_combo.get() == "Русский" else "en"
        self.update_language()
        
    def update_language(self):
        self.root.title(self.t("title"))
        self.header.config(text=self.t("header"))
        self.ip_label.config(text=self.t("ip_label"))
        self.lang_label.config(text=self.t("language"))
        self.btn_shutdown_now.config(text=self.t("btn_shutdown_now"))
        self.btn_shutdown_timer.config(text=self.t("btn_shutdown_timer"))
        self.btn_shutdown_text.config(text=self.t("btn_shutdown_text"))
        self.btn_shutdown_voice.config(text=self.t("btn_shutdown_voice"))
        self.btn_send_text.config(text=self.t("btn_send_text"))
        self.btn_send_voice.config(text=self.t("btn_send_voice"))
        self.btn_save_cred.config(text=self.t("btn_save_cred"))
        self.btn_show_saved.config(text=self.t("btn_show_saved"))
        self.btn_delete_cred.config(text=self.t("btn_delete_cred"))
        self.btn_diag.config(text=self.t("btn_diag"))
        self.btn_clear.config(text=self.t("btn_clear"))
        
    def write_output(self, text, tag=None):
        self.output.insert(END, text + "\n", tag)
        self.output.see(END)
        self.root.update()
        
    def update_progress(self, value):
        self.progress['value'] = value
        self.root.update()
        
    def run_command(self, cmd):
        try:
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
            return result.stdout.strip() or result.stderr.strip()
        except:
            return None
            
    def test_ping(self, ip):
        result = self.run_command(f"ping -n 1 {ip} | find \"TTL=\"")
        return bool(result)
        
    def get_cred_file(self, ip):
        return CRED_DIR / f"remote_cred_{ip.replace('.', '_')}.xml"
        
    def add_trusted_host(self, ip):
        self.write_output(f"  → {self.t('add_trusted', ip)}", "cmd")
        
        # Получаем текущие TrustedHosts
        current = self.run_command("winrm get winrm/config/client | findstr TrustedHosts")
        
        if current and "TrustedHosts" in current:
            current_hosts = current.split("=")[-1].strip()
            if ip in current_hosts:
                self.write_output(f"  {self.t('already_trusted', ip)}", "ok")
                return True
            new_hosts = f"{current_hosts},{ip}"
        else:
            new_hosts = ip
            
        # Добавляем IP
        result = self.run_command(f'winrm set winrm/config/client @{{TrustedHosts="{new_hosts}"}}')
        if result is not None:
            self.write_output(f"  {self.t('trusted_updated', new_hosts)}", "ok")
            return True
        else:
            self.write_output(f"  {self.t('trusted_error')}", "error")
            return False
            
    def invoke_remote_command(self, script_block, success_msg=None, fail_msg=None):
        ip = self.ip_var.get()
        cred_file = self.get_cred_file(ip)
        
        self.write_output(f"  → {self.t('checking', ip)}", "cmd")
        
        if not self.test_ping(ip):
            self.write_output(f"  {self.t('offline', ip)}", "error")
            if fail_msg:
                self.write_output(f"  {fail_msg}", "error")
            return False
            
        self.write_output(f"  {self.t('online', ip)}", "ok")
        self.update_progress(30)
        
        if not cred_file.exists():
            self.write_output(f"  {self.t('no_credentials')}", "warning")
            return False
            
        self.add_trusted_host(ip)
        self.write_output(f"  → {self.t('executing', ip)}", "cmd")
        
        # Создаём временный PowerShell скрипт
        temp_script = CRED_DIR / "temp_script.ps1"
        script_content = f"""
$cred = Import-Clixml -Path '{cred_file}'
Invoke-Command -ComputerName {ip} -Credential $cred -ScriptBlock {{
    {script_block}
}} -ErrorAction Stop
"""
        temp_script.write_text(script_content, encoding='utf-8')
        
        result = self.run_command(f'powershell -ExecutionPolicy Bypass -File "{temp_script}"')
        success = result is not None and "error" not in result.lower()
        
        temp_script.unlink(missing_ok=True)
        self.update_progress(100)
        
        if success:
            self.write_output(f"  {self.t('success')}", "ok")
            if success_msg:
                self.write_output(f"  {success_msg}", "ok")
            return True
        else:
            self.write_output(f"  {self.t('error', ip)}", "error")
            if result:
                self.write_output(f"  {result}", "error")
            if fail_msg:
                self.write_output(f"  {fail_msg}", "error")
            return False
            
    def shutdown_now(self):
        threading.Thread(target=lambda: self.invoke_remote_command("shutdown /s /f /t 0")).start()
        
    def shutdown_timer(self):
        timer = simpledialog.askstring(self.t("shutdown_timer"), self.t("enter_timer"), initialvalue="30")
        if timer and timer.isdigit():
            threading.Thread(target=lambda: self.invoke_remote_command(f"shutdown /s /f /t {timer}")).start()
            
    def shutdown_text(self):
        timer = simpledialog.askstring(self.t("shutdown_timer"), self.t("enter_timer"), initialvalue="30")
        if timer and timer.isdigit():
            message = simpledialog.askstring(self.t("shutdown_text"), self.t("enter_message"), initialvalue="Компьютер выключается")
            if message:
                cmd = f"msg * /TIME:15 '{message}'; shutdown /s /f /t {timer}"
                threading.Thread(target=lambda: self.invoke_remote_command(cmd)).start()
                
    def shutdown_voice(self):
        timer = simpledialog.askstring(self.t("shutdown_voice"), self.t("enter_timer"), initialvalue="30")
        if timer and timer.isdigit():
            message = simpledialog.askstring(self.t("shutdown_voice"), self.t("enter_voice"), initialvalue="Компьютер выключается")
            if message:
                cmd = f"""
Add-Type -AssemblyName System.Speech
$synth = New-Object System.Speech.Synthesis.SpeechSynthesizer
$synth.Speak('{message}')
shutdown /s /f /t {timer}
"""
                threading.Thread(target=lambda: self.invoke_remote_command(cmd)).start()
                
    def send_text(self):
        message = simpledialog.askstring(self.t("send_text"), self.t("enter_message"), initialvalue="Привет!")
        if message:
            def task():
                success = self.invoke_remote_command(f"msg * /TIME:30 '{message}'")
                if not success:
                    self.write_output(f"  {self.t('text_not_sent')}", "error")
            threading.Thread(target=task).start()
            
    def send_voice(self):
        message = simpledialog.askstring(self.t("send_voice"), self.t("enter_voice"), initialvalue="Привет!")
        if message:
            def task():
                cmd = f"""
Add-Type -AssemblyName System.Speech
$synth = New-Object System.Speech.Synthesis.SpeechSynthesizer
$synth.Speak('{message}')
"""
                success = self.invoke_remote_command(cmd)
                if not success:
                    self.write_output(f"  {self.t('voice_not_sent')}", "error")
            threading.Thread(target=task).start()
            
    def save_credentials(self):
        ip = self.ip_var.get()
        cred_file = self.get_cred_file(ip)
        
        self.write_output(f"  → {self.t('executing', ip)}", "cmd")
        
        try:
            # Запускаем PowerShell для получения учётных данных
            ps_script = f"""
$cred = Get-Credential -Message "Введите учётные данные для {ip}"
$cred | Export-Clixml -Path '{cred_file}'
"""
            result = self.run_command(f'powershell -Command "{ps_script}"')
            if cred_file.exists():
                self.write_output(f"  {self.t('cred_saved')}", "ok")
            else:
                self.write_output(f"  {self.t('cred_save_error')}", "error")
        except:
            self.write_output(f"  {self.t('cred_save_error')}", "error")
            
    def show_saved_ips(self):
        self.write_output("", "")
        self.write_output(self.t("saved_creds"), "header")
        
        files = list(CRED_DIR.glob("remote_cred_*.xml"))
        if not files:
            self.write_output(f"  {self.t('no_saved')}", "warning")
        else:
            for file in files:
                ip = file.stem.replace("remote_cred_", "").replace("_", ".")
                self.write_output(f"  {ip}", "result")
                
    def delete_credentials(self):
        ip = self.ip_var.get()
        cred_file = self.get_cred_file(ip)
        
        if cred_file.exists():
            cred_file.unlink()
            self.write_output(f"  {self.t('cred_deleted', ip)}", "ok")
        else:
            self.write_output(f"  {self.t('cred_not_found', str(cred_file))}", "warning")
            
    def diagnostics(self):
        ip = self.ip_var.get()
        pc_online = self.test_ping(ip)
        
        self.write_output("", "")
        self.write_output(self.t("diag_header"), "header")
        self.update_progress(10)
        
        self.write_output(self.t("diag_ping"), "subheader")
        if pc_online:
            self.write_output(f"  {self.t('online', ip)}", "ok")
        else:
            self.write_output(f"  {self.t('offline', ip)}", "error")
            self.write_output(f"  {self.t('pc_unreachable')}", "warning")
        self.update_progress(30)
        
        self.write_output(self.t("diag_winrm"), "subheader")
        if pc_online:
            result = self.run_command(f'powershell -Command "Test-WSMan {ip}"')
            if result and "error" not in result.lower():
                self.write_output(f"  {self.t('winrm_ok')}", "ok")
            else:
                self.write_output(f"  {self.t('winrm_error')}", "error")
        else:
            self.write_output(f"  {self.t('winrm_error')}", "error")
        self.update_progress(60)
        
        self.write_output(self.t("diag_port"), "subheader")
        if pc_online:
            result = self.run_command(f'powershell -Command "Test-NetConnection -ComputerName {ip} -Port 5985 | Select-Object -ExpandProperty TcpTestSucceeded"')
            if result and "True" in result:
                self.write_output(f"  {self.t('port_open')}", "ok")
            else:
                self.write_output(f"  {self.t('port_closed')}", "error")
        else:
            self.write_output(f"  {self.t('port_closed')}", "error")
        self.update_progress(90)
        
        self.write_output(self.t("diag_complete"), "ok")
        self.update_progress(100)
        time.sleep(1)
        self.update_progress(0)
        
    def clear_output(self):
        self.output.delete(1.0, END)
        self.update_progress(0)

